# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_NAME=voice-agent

# Groq (free tier)
GROQ_API_KEY=
GROQ_LLM_MODEL=openai/gpt-oss-120b

# Cartesia TTS — https://play.cartesia.ai
CARTESIA_API_KEY=sk_car_AMaN2AfyJbJTNnb6hWm9wp
CARTESIA_TTS_MODEL=sonic-3
CARTESIA_TTS_VOICE=6f84f4b8-58a2-430c-8c79-688dad597532

# Turn-taking latency (seconds) — lower = snappier
AGENT_ENDPOINTING_MIN=0.2
AGENT_ENDPOINTING_MAX=0.8
AGENT_PREEMPTIVE_TTS=true
AGENT_VAD_ACTIVATION=0.4
AGENT_VAD_MIN_SILENCE=0.25

# Timezone for calendar booking (voice assistant)
USER_TIMEZONE=Asia/Kolkata

# Google OAuth — add when ready
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRE_MINUTES=1440

# Database (SQLite locally; Render uses Postgres from render.yaml)
DATABASE_URL=sqlite:///./data/app.db

# URLs
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-app.vercel.app
# GOOGLE_REDIRECT_URI=https://agent-demo-api.onrender.com/auth/callback
