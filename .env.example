# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_NAME=voice-agent

# Groq (free tier)
GROQ_API_KEY=
GROQ_LLM_MODEL=openai/gpt-oss-120b
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=autumn

# Timezone for calendar booking (voice assistant)
USER_TIMEZONE=Asia/Kolkata

# Google OAuth — add when ready
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRE_MINUTES=1440

# Database (SQLite locally; Render uses Postgres from render.yaml)
DATABASE_URL=sqlite:///./data/app.db

# URLs
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-app.vercel.app
# GOOGLE_REDIRECT_URI=https://agent-demo-api.onrender.com/auth/callback
