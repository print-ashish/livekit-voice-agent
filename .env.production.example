# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_NAME=voice-agent

# Groq
GROQ_API_KEY=
GROQ_LLM_MODEL=openai/gpt-oss-20b

# Cartesia STT + TTS
CARTESIA_API_KEY=
CARTESIA_STT_MODEL=ink-2
CARTESIA_TTS_MODEL=sonic-3
CARTESIA_TTS_VOICE=6f84f4b8-58a2-430c-8c79-688dad597532

# Turn-taking latency
AGENT_ENDPOINTING_MIN=0.2
AGENT_ENDPOINTING_MAX=0.8
AGENT_PREEMPTIVE_TTS=true
AGENT_VAD_ACTIVATION=0.4
AGENT_VAD_MIN_SILENCE=0.25

# Timezone for calendar booking
USER_TIMEZONE=Asia/Kolkata

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/auth/callback

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRE_MINUTES=1440

# SQLite shared by api + agent
DATABASE_URL=sqlite:///./data/app.db

# Frontend URL (Vercel)
FRONTEND_URL=https://livekit-voice-agent-gules.vercel.app
